{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "trezo": {
            "projectType": "application",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "scss"
                }
            },
            "root": "",
            "sourceRoot": "src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:application",
                    "options": {
                        "outputPath": "dist/trezo",
                        "index": "src/index.html",
                        "browser": "src/main.ts",
                        "polyfills": ["zone.js"],
                        "tsConfig": "tsconfig.app.json",
                        "inlineStyleLanguage": "scss",
                        "assets": [
                            {
                                "glob": "**/*",
                                "input": "public"
                            }
                        ],

                        "styles": [
                            "node_modules/minireset.css/minireset.css",
                            "node_modules/quill/dist/quill.snow.css",
                            "@angular/material/prebuilt-themes/azure-blue.css",
                            "node_modules/ngx-owl-carousel-o/lib/styles/prebuilt-themes/owl.carousel.min.css",
                            "node_modules/ngx-owl-carousel-o/lib/styles/prebuilt-themes/owl.theme.default.min.css",
                            "node_modules/remixicon/fonts/remixicon.css",
                            "node_modules/ngx-lightbox/lightbox.css",
                            "node_modules/bootstrap/dist/css/bootstrap.min.css",
                            "node_modules/igniteui-angular/styles/igniteui-angular.css",
                            "src/styles.scss",
                            "src/global.css"
                        ],
                        "scripts": [
                            "node_modules/apexcharts/dist/apexcharts.min.js",
                            "node_modules/bootstrap/dist/js/bootstrap.bundle.min.js",
                            "./node_modules/hammerjs/hammer.min.js"
                        ],
                        "server": "src/main.server.ts",
                        "prerender": false,
                        "ssr": false,
                        "stylePreprocessorOptions": {
                            "includePaths": ["node_modules"]
                        }
                    },
                    "configurations": {
                        "production": {
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "7MB",
                                    "maximumError": "10MB"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "1MB",
                                    "maximumError": "2MB"
                                }
                            ],
                            "optimization": {
                                "fonts": {
                                    "inline": false
                                }
                            },
                            "outputHashing": "all"
                        },
                        "stag": {
                            "fileReplacements": [
                                {
                                    "replace": "src/environments/environment.ts",
                                    "with": "src/environments/environment.stage.ts"
                                }
                            ],
                            "optimization": {
                                "fonts": {
                                    "inline": false
                                }
                            },
                            "outputHashing": "all"
                        },
                         "trypdek_stag": {
                            "fileReplacements": [
                                {
                                    "replace": "src/environments/environment.ts",
                                    "with": "src/environments/environment.trypdek.stage.ts"
                                }
                            ],
                            "optimization": {
                                "fonts": {
                                    "inline": false
                                }
                            },
                            "outputHashing": "all"
                        },
                        "trypdek_dev": {
                            "fileReplacements": [
                                {
                                    "replace": "src/environments/environment.ts",
                                    "with": "src/environments/environment.trypdek.dev.ts"
                                }
                            ],
                            "optimization": {
                                "fonts": {
                                    "inline": false
                                }
                            },
                            "outputHashing": "all"
                        },
                        "dev": {
                            "fileReplacements": [
                                {
                                    "replace": "src/environments/environment.ts",
                                    "with": "src/environments/environment.ts"
                                }
                            ],
                            "optimization": {
                                "fonts": {
                                    "inline": false
                                }
                            },
                            "outputHashing": "all"
                        },
                        "development": {
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true,
                            "fileReplacements": [
                                {
                                    "replace": "src/environments/environment.ts",
                                    "with": "src/environments/environment.development.ts"
                                }
                            ]
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "configurations": {
                        "production": {
                            "buildTarget": "trezo:build:production"
                        },
                        "development": {
                            "buildTarget": "trezo:build:development"
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "extract-i18n": {
                    "builder": "@angular-devkit/build-angular:extract-i18n"
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "polyfills": ["zone.js", "zone.js/testing"],
                        "tsConfig": "tsconfig.spec.json",
                        "inlineStyleLanguage": "scss",
                        "assets": [
                            {
                                "glob": "**/*",
                                "input": "public"
                            }
                        ],
                        "styles": [
                            "@angular/material/prebuilt-themes/azure-blue.css",
                            "src/styles.scss"
                        ],
                        "scripts": ["./node_modules/hammerjs/hammer.min.js"],
                        "stylePreprocessorOptions": {
                            "includePaths": ["node_modules"]
                        }
                    }
                }
            }
        }
    },
    "cli": {
        "analytics": false
    }
}
